---
interface Props {
  href: string;
  number: string;
  title: string;
  description?: string;
  date: Date;
  /** optional small label above the title, e.g. the series name */
  eyebrow?: string;
}

const { href, number, title, description, date, eyebrow } = Astro.props;

const formatted = date.toLocaleDateString("en-GB", {
  day: "2-digit",
  month: "short",
  year: "numeric",
  timeZone: "UTC",
});
---

<a href={href} class="row">
  <span class="number label label--accent">{number}</span>
  <span class="body">
    {eyebrow && <span class="eyebrow label">{eyebrow}</span>}
    <span class="title">{title}</span>
    {description && <span class="description">{description}</span>}
  </span>
  <span class="date label">{formatted}</span>
</a>

<style>
  .row {
    display: grid;
    grid-template-columns: 3.5rem 1fr auto;
    gap: 1.25rem;
    align-items: baseline;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--rule);
    text-decoration: none;
  }

  .row:hover .title {
    color: var(--accent);
  }

  .eyebrow {
    display: block;
    margin-bottom: 0.35rem;
    color: var(--accent);
  }

  .title {
    display: block;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .description {
    display: block;
    margin-top: 0.35rem;
    font-size: 0.8125rem;
    color: var(--ink-soft);
  }

  .date {
    white-space: nowrap;
  }

  @media (max-width: 540px) {
    .row {
      grid-template-columns: 3.5rem 1fr;
    }

    .date {
      grid-column: 2;
    }
  }
</style>
