---
import "katex/dist/katex.min.css";
import Base from "./Base.astro";

interface Props {
  kind: string;
  number: string;
  title: string;
  description?: string;
  date: Date;
  tags?: string[];
  backHref: string;
  backLabel: string;
}

const { kind, number, title, description, date, tags = [], backHref, backLabel } =
  Astro.props;

const formatted = date.toLocaleDateString("en-GB", {
  day: "2-digit",
  month: "short",
  year: "numeric",
});
---

<Base title={`${title} — Zuhaib Ul Zamann`} description={description}>
  <article>
    <header class="masthead">
      <a href={backHref} class="back label">← {backLabel}</a>
      <div class="plate">
        <div class="plate-meta">
          <span class="label label--accent">{kind} № {number}</span>
          <span class="label">{formatted}</span>
        </div>
        <h1>{title}</h1>
        {description && <p class="standfirst">{description}</p>}
        {
          tags.length > 0 && (
            <ul class="tags">
              {tags.map((t) => (
                <li>{t}</li>
              ))}
            </ul>
          )
        }
      </div>
    </header>

    <div class="prose">
      <slot />
    </div>
  </article>
</Base>

<style>
  article {
    padding-top: 2.5rem;
  }

  .back {
    text-decoration: none;
    display: inline-block;
    margin-bottom: 2rem;
  }

  .back:hover {
    color: var(--accent);
  }

  .plate {
    border-top: 3px solid var(--rule-strong);
    border-bottom: 1px solid var(--rule);
    padding: 1.25rem 0 1.5rem;
    margin-bottom: 3rem;
    max-width: var(--measure);
  }

  .plate-meta {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.25rem;
  }

  h1 {
    font-size: clamp(1.5rem, 4vw, 2.125rem);
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: 0.01em;
    text-transform: uppercase;
  }

  .standfirst {
    margin-top: 1rem;
    color: var(--ink-soft);
    font-style: italic;
  }

  .tags {
    list-style: none;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 1.25rem;
  }

  .tags li {
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: 1px solid var(--rule);
    padding: 0.1rem 0.5rem;
    color: var(--ink-soft);
  }
</style>
