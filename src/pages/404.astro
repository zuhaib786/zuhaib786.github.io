---
import Base from "../layouts/Base.astro";
---

<Base title="404 — Page not found">
  <section class="notfound">
    <p class="label label--accent">Error № 404</p>
    <h1>Page Not Found</h1>
    <p>
      This page doesn't exist in the manual. <a href="/">Return to the
      contents page</a>.
    </p>
  </section>
</Base>

<style>
  .notfound {
    padding: 6rem 0;
  }

  h1 {
    font-size: clamp(2rem, 6vw, 3.5rem);
    font-weight: 700;
    text-transform: uppercase;
    margin: 1rem 0;
  }

  p {
    color: var(--ink-soft);
  }
</style>
