---
import Base from "../layouts/Base.astro";

const contact = [
  { label: "zuhaibulzaman.786@gmail.com", href: "mailto:zuhaibulzaman.786@gmail.com" },
  { label: "github.com/zuhaib786", href: "https://github.com/zuhaib786" },
  { label: "Srinagar J&K, India" },
];

const experience = [
  {
    role: "Senior Machine Learning Engineer",
    org: "Sprinklr",
    period: "Jun 2023 – Present",
    items: [
      {
        heading: "Agentic Copilots for Marketing & Social Suites",
        link: "https://engineering.sprinklr.com/building-embedded-ai-agents-that-works-the-sprinklr-copilot-blueprint-bc2505f5c6bd",
        points: [
          "Shipped production copilots that answer user queries about their social and marketing data, replacing manual dashboard navigation with natural language — achieving 90% satisfactory resolution across 3K queries/month.",
          "Built as a shared platform so each product team could plug in their own data context instead of rebuilding from scratch, enabling rapid adoption across the organization.",
        ],
      },
      {
        heading: "Cloud Cost Optimization & Telemetry Framework",
        points: [
          "Architected cost telemetry across 1,000+ microservices and 500-node clusters enabling precise per-microservice attribution, driving $100K+/month in infrastructure savings over 2 years.",
          "Automated resource reconciliation and intelligent rollback, cutting per-quarter spend by $20K–$30K and lifting cluster utilization from 50% to 70%+.",
          "Built proactive alerting for abnormal cost spikes across a large-scale multi-cloud environment, preventing undetected runaway spend.",
        ],
      },
      {
        heading: "Observability & Distributed Tracing Platform",
        points: [
          "Designed error and latency telemetry for distributed microservices using Elasticsearch, compressing RCA time from 30–40 minutes to under 6 minutes and eliminating manual log triage.",
          "Framework voluntarily adopted by multiple independent engineering teams without mandate after eliminating pod-retry cycles entirely.",
        ],
      },
      {
        heading: "Resiliency & Automated Auditing System",
        points: [
          "Enforcement-by-design auditing across 100–200 microservices — mandating HA minimums, replica bounds, DNS-only discovery, and proxy-mediated DB connections — lifted platform uptime from 95% to 99.999%.",
          "Rules enforced at deploy time, not detected after the fact, eliminating entire classes of mis-configuration at the source.",
        ],
      },
    ],
  },
];

const skills = [
  { group: "Languages", list: "Python, Java, C/C++" },
  {
    group: "Cloud & Infrastructure",
    list: "AWS, GCP, Kubernetes, Docker, Linkerd (Service Mesh), Keda, Terraform",
  },
  {
    group: "Databases & Tools",
    list: "Elasticsearch, Redis, MongoDB, S3, CI/CD Pipelines",
  },
  {
    group: "Core Competencies",
    list: "Distributed Systems, Microservices Architecture, Cloud Cost Optimization, System Design",
  },
];

const education = [
  {
    degree: "M.Tech",
    college: "Indian Institute of Technology Delhi",
    period: "2022 – 2023",
    gpa: "10.0/10.0",
  },
  {
    degree: "B.Tech",
    college: "Indian Institute of Technology Delhi",
    period: "2018 – 2022",
    gpa: "9.414/10.0",
  },
];

const awards = [
  "Departmental Rank 2 — Ranked second in my batch; perfect GPA of 10.0/10.0 during M.Tech.",
  "Best Thesis Award — Recognized for M.Tech thesis on Discontinuity Identification using Graph Neural Networks.",
  "IIT Delhi Merit Prize — Awarded for six consecutive semesters (Top 7% performers in department).",
];
---

<Base
  title="Résumé — Zuhaib Ul Zamann"
  description="Résumé of Zuhaib Ul Zamann — ML engineering, distributed systems, and agentic AI."
>
  <section class="listing">
    <header>
      <p class="label label--accent">Section 05</p>
      <h1>Résumé</h1>
      <p class="standfirst">
        ML Engineering · Distributed Systems · Agentic AI
      </p>
      <ul class="contact">
        {
          contact.map((c) => (
            <li>{c.href ? <a href={c.href}>{c.label}</a> : c.label}</li>
          ))
        }
      </ul>
    </header>

    <h2 class="section-title label">Experience</h2>
    {
      experience.map((job) => (
        <div class="block job">
          <div class="job-head">
            <div>
              <p class="strong">{job.role}</p>
              <p class="muted">{job.org}</p>
            </div>
            <span class="label period">{job.period}</span>
          </div>
          {job.items.map((item) => (
            <div class="job-item">
              <p class="item-heading">
                {item.heading}
                {item.link && (
                  <a class="item-link" href={item.link}>Blog ↗</a>
                )}
              </p>
              <ul class="points">
                {item.points.map((pt) => (
                  <li>{pt}</li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      ))
    }

    <h2 class="section-title label">Technical Skills</h2>
    <div class="block">
      <table>
        {
          skills.map((s) => (
            <tr>
              <th>{s.group}</th>
              <td>{s.list}</td>
            </tr>
          ))
        }
      </table>
    </div>

    <h2 class="section-title label">Education</h2>
    <div class="block">
      {
        education.map((e) => (
          <div class="edu">
            <div>
              <p class="strong">
                {e.degree} — {e.college}
              </p>
              <p class="muted">GPA: {e.gpa}</p>
            </div>
            <span class="label period">{e.period}</span>
          </div>
        ))
      }
    </div>

    <h2 class="section-title label">Awards &amp; Achievements</h2>
    <ul class="block points">
      {awards.map((a) => <li>{a}</li>)}
    </ul>
  </section>
</Base>

<style>
  .listing {
    padding-top: 2.5rem;
    max-width: var(--measure);
  }

  header {
    border-bottom: 3px solid var(--rule-strong);
    padding-bottom: 1.5rem;
  }

  h1 {
    font-size: clamp(1.75rem, 5vw, 2.75rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    margin: 0.75rem 0;
  }

  .standfirst {
    color: var(--ink-soft);
  }

  .contact {
    list-style: none;
    display: flex;
    gap: 0.75rem 1.5rem;
    flex-wrap: wrap;
    margin-top: 1rem;
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    color: var(--ink-soft);
  }

  .contact li + li::before {
    content: "· ";
    color: var(--ink-faint);
    margin-right: 0.25rem;
  }

  .section-title {
    margin-top: 3rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--rule-strong);
  }

  .section-title::before {
    content: "§ ";
    color: var(--accent);
  }

  .block {
    margin-top: 1.25rem;
  }

  .strong {
    font-weight: 600;
  }

  .muted {
    color: var(--ink-soft);
    font-size: 0.875rem;
  }

  .edu,
  .job-head {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .edu + .edu {
    margin-top: 1rem;
  }

  .period {
    white-space: nowrap;
  }

  .job-item {
    margin-top: 1.25rem;
  }

  .item-heading {
    font-weight: 600;
    font-size: 0.875rem;
    letter-spacing: 0.03em;
    margin-bottom: 0.5rem;
  }

  .item-heading::before {
    content: "▸ ";
    color: var(--accent);
  }

  .item-link {
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border: 1px solid var(--rule);
    padding: 0.1rem 0.5rem;
    margin-left: 0.6rem;
    text-decoration: none;
    color: var(--accent);
    white-space: nowrap;
  }

  .item-link:hover {
    background: var(--accent);
    color: var(--paper);
  }

  .points {
    list-style: none;
    font-size: 0.875rem;
    color: var(--ink-soft);
  }

  .points li {
    padding-left: 1.25rem;
    position: relative;
  }

  .points li::before {
    content: "—";
    position: absolute;
    left: 0;
    color: var(--accent);
  }

  .points li + li {
    margin-top: 0.4rem;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  th,
  td {
    border: 1px solid var(--rule);
    padding: 0.6em 0.85em;
    text-align: left;
    vertical-align: top;
  }

  th {
    background: var(--paper-sunken);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    white-space: nowrap;
  }
</style>
